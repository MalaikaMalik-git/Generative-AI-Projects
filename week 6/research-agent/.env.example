OPENAI_API_KEY=sk-your-openai-key-here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langchain-key-here
LANGCHAIN_PROJECT=research-agent
OPENAI_MODEL=gpt-4o-mini
# ── API Auth ─────────────────────────────────────────────────────────────────────
# Comma-separated list of valid API keys for this server
ALLOWED_API_KEYS=dev-key-1234,test-key-5678,rate-test-key-999

# ── Rate Limiting ────────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=3600

# ── Agent Config ─────────────────────────────────────────────────────────────────
MAX_STEPS=6
MAX_SEARCH_RESULTS=5
REQUEST_TIMEOUT=5

# ── Production (set on Railway/Vercel, not needed locally) ──────────────────────
# FRONTEND_URL=https://your-app.vercel.app
